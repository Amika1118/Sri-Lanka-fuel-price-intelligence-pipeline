# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS General ───────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_KEY>

# ── S3 Data Lake ──────────────────────────────────────────────────────────────
# Bucket layout:
#   raw/crude_oil/          ← EIA Brent price JSON files
#   raw/fx_rates/           ← Monthly USD/LKR JSON files
#   raw/sl_fuel_prices/     ← CPC scraped + Kaggle historical JSON
#   reference/              ← Kaggle static CSV (uploaded manually once)
#   redshift-temp/          ← Glue ↔ Redshift temp dir (auto-managed)
S3_BUCKET=cm2606-fuel-pipeline-<YOUR-SUFFIX>

# ── EIA Open Data API ─────────────────────────────────────────────────────────
# Register free at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=<YOUR_EIA_API_KEY>

# ── FX Rates API ─────────────────────────────────────────────────────────────
# Free tier at: https://exchangerate.host  (no key required for basic use)
# LOOKBACK_DAYS: how many days of history to fetch on each run
LOOKBACK_DAYS=730

# ── Amazon Redshift (Data Warehouse) ─────────────────────────────────────────
# Create a Redshift Serverless workgroup or provisioned cluster
REDSHIFT_URL=jdbc:redshift://<cluster-endpoint>:5439/<db-name>
REDSHIFT_DB=fuel_intelligence
REDSHIFT_USER=admin
REDSHIFT_PASS=<YOUR_REDSHIFT_PASSWORD>
# IAM role ARN that grants Glue access to Redshift and S3
REDSHIFT_ROLE_ARN=arn:aws:iam::<ACCOUNT_ID>:role/GlueRedshiftAccessRole

# ── AWS Glue ──────────────────────────────────────────────────────────────────
GLUE_JOB_NAME=sl-fuel-price-etl
GLUE_ROLE_ARN=arn:aws:iam::<ACCOUNT_ID>:role/GlueJobRole
GLUE_PYTHON_VERSION=3
GLUE_WORKER_TYPE=G.1X
GLUE_NUM_WORKERS=2
